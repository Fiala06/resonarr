# Copy to .env and fill in. .env is gitignored — secrets never get committed.

# --- Plex (server-side only) ---
# Base URL of your Plex server, e.g. http://192.168.1.10:32400
PLEX_URL=
# Plex auth token. How to find it:
# https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=

# --- Lidarr (server-side only) ---
# Base URL of Lidarr, e.g. http://192.168.1.10:8686
LIDARR_URL=
# Lidarr API key: Settings > General > Security > API Key
LIDARR_API_KEY=

# --- LLM provider (Sonic Sage) ---
# Active provider: claude | openai | ollama
LLM_PROVIDER=claude
# Used only by the matching provider:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434

# --- App ---
# Port the server listens on
PORT=8080
# Where the SQLite DB + settings live. Defaults to /config in the container,
# or <repo>/.data in local dev. Override here if you want a custom path.
# DATA_DIR=/config
